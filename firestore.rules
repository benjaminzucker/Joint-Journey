rules_version = '2';

// Joint Journey Firestore Security Rules
// Each user can only read/write their own document
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User documents: only accessible by the authenticated user who owns them
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Feedback: any signed-in user can submit (create) feedback.
    // No one can read/update/delete from the client - you review it in the
    // Firebase console. This keeps other users' feedback private.
    // Hardened: the submitter cannot spoof another user's uid, and the
    // message is length-capped to limit abuse / oversized writes.
    match /feedback/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.message is string
                    && request.resource.data.message.size() < 5000;
      allow read, update, delete: if false;
    }

    // Block all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
